{
  "manifest_version": 3,
  "name": "DailyTrial MD Preview",
  "version": "1.0.0",
  "description": "DailyTrialの独自Markdown構文を本番同等のデザインでプレビューするChrome拡張機能",
  "content_scripts": [
    {
      "matches": ["file:///*.md", "file:///*.markdown", "file:///*/"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": []
}
