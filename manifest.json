{
  "manifest_version": 3,
  "name": "DailyTrial MD Preview",
  "version": "1.0.0",
  "description": "DailyTrialの独自Markdown構文を本番同等のデザインでプレビューするChrome拡張機能",
  "content_scripts": [
    {
      "matches": ["file:///*.md", "file:///*.markdown"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "activeTab"]
}
